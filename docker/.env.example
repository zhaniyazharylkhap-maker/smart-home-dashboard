POSTGRES_USER=smarthome
POSTGRES_PASSWORD=smarthome
POSTGRES_DB=smarthome

# Published to your Mac as this port (container still listens on 5432 internally).
# Use 5432 here only if nothing else is bound to 5432 on the host.
POSTGRES_PORT=5433

# Must match between backend and any client that validates JWTs locally
JWT_SECRET=change-me-in-production-use-long-random-string
